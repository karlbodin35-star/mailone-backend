{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    { "path": "/api/cron/emails",                        "schedule": "0 7 * * *"  },
    { "path": "/api/notifications/cron/morning",         "schedule": "0 7 * * *"  },
    { "path": "/api/notifications/cron/afternoon",       "schedule": "0 14 * * *" }
  ]
}
