# ══════════════════════════════════════════════════════════════
# MAILONE BACKEND — Variables d'environnement
# Copiez ce fichier en .env et remplissez toutes les valeurs
# NE JAMAIS COMMITTER le fichier .env sur Git
# ══════════════════════════════════════════════════════════════

# ── SERVEUR ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# En production :
# FRONTEND_URL=https://mailone.app

# ── JWT (générez une clé secrète longue et aléatoire) ────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACEZ_PAR_UNE_CLE_SECRETE_LONGUE_ET_ALEATOIRE
JWT_EXPIRES_IN=7d

# ── SUPABASE ─────────────────────────────────────────────────
# Récupérez ces valeurs sur https://app.supabase.com
# Projet → Settings → API
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# ── STRIPE ───────────────────────────────────────────────────
# Récupérez sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET

# Price IDs — créez vos produits sur Stripe Dashboard
# Stripe Dashboard → Produits → Créer un produit → Ajouter un tarif
STRIPE_PRICE_SOLO_MONTHLY=price_XXXX       # 99€/mois
STRIPE_PRICE_SOLO_ANNUAL=price_XXXX        # 990€/an
STRIPE_PRICE_TEAM_MONTHLY=price_XXXX       # 900€/mois
STRIPE_PRICE_TEAM_ANNUAL=price_XXXX        # 9000€/an
STRIPE_PRICE_ENT_MONTHLY=price_XXXX        # 1780€/mois
STRIPE_PRICE_ENT_ANNUAL=price_XXXX         # 17800€/an

# ── RESEND (emails transactionnels) ──────────────────────────
# Créez un compte sur https://resend.com
# Ajoutez et vérifiez votre domaine dans Resend
RESEND_API_KEY=re_VOTRE_CLE_API
EMAIL_FROM=MailOne <noreply@mailone.app>
EMAIL_SUPPORT=support@mailone.app

# ── ANTHROPIC (IA MailOne Pro) ───────────────────────────────
# Récupérez sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_API

# ── CRON SECRET (sécurise l'endpoint /api/cron/emails) ───────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=REMPLACEZ_PAR_UNE_CLE_ALEATOIRE
