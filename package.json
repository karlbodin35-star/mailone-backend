{
  "name": "mailone-backend",
  "version": "1.0.0",
  "description": "MailOne Backend — Auth, Stripe, Supabase, Emails",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step needed'",
    "test": "jest --forceExit --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000,
    "clearMocks": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.2",
    "languagedetect": "^2.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.3",
    "resend": "^2.1.0",
    "stripe": "^14.11.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sharp": "^0.35.3",
    "supertest": "^6.3.4"
  }
}
